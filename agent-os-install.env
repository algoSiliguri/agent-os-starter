# Shared lifecycle install targets for agent-os-starter.
# This is the single source of truth for setup, update, doctor, uninstall,
# user-install smoke, and release readiness checks.

# Immutable release source for normal user installs.
AGENT_OS_INSTALL_REF="git:github.com/algoSiliguri/Agent_OS@v1.6.1"
AGENT_OS_EXPECTED_VERSION="1.6.1"
AGENT_OS_INSTALL_CHANNEL="released"

KNOWLEDGE_BRAIN_INSTALL_REF="git+https://github.com/agnivadc/knowledge-brain.git@v1.0.1"
KNOWLEDGE_BRAIN_EXPECTED_VERSION="1.0.1"

MIN_PI_VERSION="0.74.0"
INSTALL_MANIFEST_SCHEMA_VERSION="1"
